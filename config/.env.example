# 🖧 LCon — Python TUI Client Configuration
# 📋 Priority: env var > .env file > hardcoded default
# 📂 Copy to config/.env and edit:
# 💡     cp config/.env.example config/.env
# 🔄 Changes take effect on next launch

# 🌐 WebSocket server address
LCON_HOST=localhost

# 🔌 WebSocket server port
LCON_PORT=58115

# 🔑 Auth token (leave empty to disable)
LCON_TOKEN=your_secret_token

# 📃 Enable soft word wrap in console log (true / false)
LCON_SOFT_WRAP=true

# 🗑️ Max lines to keep in console log buffer (oldest lines auto-pruned)
LCON_LOG_BUFFER=1000

# ➕ Auto-prepend prefix ([server]/[client]/etc.) to messages (true / false)
LCON_AUTO_MODE=true
